# Palletium Mobile Environment Variables

# API URL - Backend server
EXPO_PUBLIC_API_URL=http://localhost:3001

# Stripe Publishable Key
# Get from: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Direct-to-S3 uploads (presigned PUT, bypasses Express)
# Enabled by default on preview/production builds (eas.json).
# Requires DIRECT_UPLOADS_ENABLED=true on the API (Railway env var).
# Set to 'false' locally to use legacy XHR upload path.
EXPO_PUBLIC_DIRECT_UPLOADS=false

# Debug upload UI — shows on-screen Alerts and debug panel in preview builds
# Set to 'true' in eas.json preview profile; never enable in production.
EXPO_PUBLIC_DEBUG_UPLOAD_UI=false